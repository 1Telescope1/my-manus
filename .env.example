# -------------------- 对外访问 --------------------
APP_PORT=8088

# -------------------- PostgreSQL --------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=manus

# -------------------- Redis --------------------
REDIS_DB=0
REDIS_PASSWORD=

# -------------------- API --------------------
API_ENV=production
API_LOG_LEVEL=INFO
API_APP_CONFIG_FILEPATH=/app/data/config.yaml
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/manus

LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL_NAME=deepseek-reasoner
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192

# 腾讯云 COS（可选；留空时文件上传功能不可用）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
COS_SCHEME=https
COS_BUCKET=
COS_DOMAIN=

SANDBOX_ADDRESS=sandbox
SANDBOX_IMAGE=manus-sandbox:latest
SANDBOX_NAME_PREFIX=manus-sandbox
SANDBOX_TTL_MINUTES=60
SANDBOX_NETWORK=

# -------------------- Sandbox --------------------
SANDBOX_LOG_LEVEL=INFO
SANDBOX_SERVER_TIMEOUT_MINUTES=0
SANDBOX_CHROME_ARGS=
SANDBOX_HTTPS_PROXY=
SANDBOX_HTTP_PROXY=
SANDBOX_NO_PROXY=localhost,127.0.0.1,sandbox,api,redis,postgres

# -------------------- UI --------------------
NEXT_PUBLIC_API_BASE_URL=/api
