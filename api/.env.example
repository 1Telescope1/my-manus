# Project base config. ENV is kept for Python parity; NODE_ENV is optional for Node conventions.
ENV=development
NODE_ENV=development
PORT=8080
API_PORT=8000
LOG_LEVEL=DEBUG
APP_CONFIG_FILEPATH=config.yaml

# Database config. SQLALCHEMY_DATABASE_URI mirrors Python. DATABASE_URL is optional Prisma-native form.
SQLALCHEMY_DATABASE_URI=
DATABASE_URL=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=manus
POSTGRES_PORT=5432

# Redis config.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_HOST_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Tencent COS config.
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
COS_SCHEME=
COS_BUCKET=
COS_DOMAIN=

# Sandbox config, preserved for Python parity and future TS migration.
SANDBOX_ADDRESS=
SANDBOX_IMAGE=
SANDBOX_NAME_PREFIX=
SANDBOX_TTL_MINUTES=
SANDBOX_NETWORK=
SANDBOX_CHROME_ARGS=
SANDBOX_HTTPS_PROXY=
SANDBOX_HTTP_PROXY=
SANDBOX_NO_PROXY=
